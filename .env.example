# MongoDB Configuration
MONGODB_URI=your_mongodb_connection_string_here
MONGODB_DB_NAME=goldenedge

# JWT Secret (change this in production!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Optional: MongoDB TLS settings (only if needed)
# MONGODB_TLS_ALLOW_INVALID_CERTIFICATES=false

# When MongoDB is unreachable (e.g. Atlas IP not whitelisted), allow dev login with demo user.
# Set USE_OFFLINE_AUTH=true then login with: demo@goldenedge.ai / demo123
# USE_OFFLINE_AUTH=true

# Optional: longer timeout for slow networks (default 30000 ms)
# MONGODB_TIMEOUT_MS=30000

# Digital Marketing API Configuration (for Analytics Page Views)
# If not configured, page views will be estimated from order data
# DIGITAL_MARKETING_API_URL=https://your-api-endpoint.com/api/page-views
# DIGITAL_MARKETING_API_KEY=your-api-key-here
